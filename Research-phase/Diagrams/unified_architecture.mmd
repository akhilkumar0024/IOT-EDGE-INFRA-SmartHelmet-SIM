graph TB
    %% Unified Smart Helmet Mega-Architecture Diagram
    %% Global Styling
    classDef ecs fill:#FF9900,stroke:#232F3E,stroke-width:2px,color:white;
    classDef sqs fill:#FF4F8B,stroke:#232F3E,stroke-width:2px,color:white;
    classDef db fill:#402770,stroke:#232F3E,stroke-width:2px,color:white;
    classDef iot fill:#3B48CC,stroke:#232F3E,stroke-width:2px,color:white;
    classDef sfn fill:#D05C0B,stroke:#232F3E,stroke-width:2px,color:white;
    classDef monitor fill:#333333,stroke:#E0E0E0,stroke-width:1px,color:white;

    %% --------------------------------------------------------
    %% PLANE 1: DATA INGESTION (DATA PLANE)
    %% --------------------------------------------------------
    subgraph Edge ["Edge Layer (Devices)"]
        H["Smart Helmet Sensors and Edge AI"]
        S["Smartphone App"]
        H -- "Bluetooth" --> S
    end

    subgraph Ingestion ["Ingestion and Broker Layer (IoT Core)"]
        MQTT["AWS IoT Core Broker"]
        Rules["IoT Rules Engine"]
        MQTTStatus["Alert Status Topic"]:::iot
        S -- "MQTT Telemetry" --> MQTT
    end

    subgraph DataCompute ["Ingestion Compute (ECS Fargate)"]
        ALB["Application Load Balancer"]
        TeleInfra["Telemetry Infra"]:::ecs
    end

    subgraph CoreQueues ["Ingestion Queues (SQS)"]
        CrashQ["Crash Queue"]:::sqs
        ControlQ["Control Queue"]:::sqs
        LWTQ["LWT Queue"]:::sqs
    end

    subgraph CoreStorage ["High Velocity Storage"]
        HotDB["DynamoDB Hot Storage"]:::db
    end

    %% Connections
    MQTT --> Rules
    Rules -- "HTTP POST" --> ALB
    ALB --> TeleInfra
    TeleInfra -- "Write Telemetry" --> HotDB
    TeleInfra -- "Check Flags" --> CrashQ
    TeleInfra -- "Graceful Shutdown" --> ControlQ
    Rules -- "Disconnect" --> LWTQ

    %% --------------------------------------------------------
    %% PLANE 2: VALIDATION & ORCHESTRATION (CONTROL PLANE)
    %% --------------------------------------------------------
    subgraph ValidationCompute ["Validation Compute (ECS Fargate)"]
        ProcInfra["Processing Infra"]:::ecs
    end

    subgraph AlertQueues ["Alert Lifecycle Queues (SQS)"]
        AlertQ["Alert Queue"]:::sqs
        OverrideQ["Override Queue"]:::sqs
    end

    subgraph AlertCompute ["Alerting Compute (ECS Fargate)"]
        AlertInfra["Alerting Infra<br>(Stateless Dispatcher)"]:::ecs
    end

    subgraph Orchestration ["Orchestration (Step Functions)"]
        SFN["Step Function Execution<br>(Wait States + SDK)"]:::sfn
    end

    subgraph PersistentState ["System State and Audit"]
        ExecReg["Execution Registry"]:::db
        ColdDB["Cold Storage Audit"]:::db
        SSM["SSM Parameter Store"]
    end

    subgraph External ["External Notifications (Out-of-Band)"]
        NOK["Next of Kin (SMS)"]
        EMS["Emergency Services (API)"]
    end

    %% Connections
    CrashQ --> ProcInfra
    ControlQ --> ProcInfra
    LWTQ --> ProcInfra
    ProcInfra -- "Context Check" --> HotDB
    ProcInfra -- "Confirmed Crash" --> AlertQ
    
    AlertQ --> AlertInfra
    AlertInfra -- "Start Workflow" --> SFN
    AlertInfra -- "Lock Execution" --> ExecReg
    SFN -- "Get Timers" --> SSM
    
    %% Alert Actions
    SFN -- "SDK Integration" --> MQTTStatus
    MQTTStatus -- "helmet/alert/status" --> S
    SFN -- "Fire Alert" --> NOK
    SFN -- "Fire Alert" --> EMS
    SFN -- "Audit Log" --> ColdDB

    %% Override Path
    S -- "Cancel Alert" --> MQTT
    Rules -- "Route Override" --> OverrideQ
    OverrideQ --> AlertInfra
    AlertInfra -- "Lookup ARN" --> ExecReg
    AlertInfra -- "Terminate" --> SFN

    %% --------------------------------------------------------
    %% PLANE 3: OBSERVABILITY (OPERATIONS PLANE)
    %% --------------------------------------------------------
    subgraph Monitoring ["Observability Stack"]
        Prometheus["Prometheus"]:::monitor
        Grafana["Grafana"]:::monitor
        Alertmanager["Alertmanager"]:::monitor
    end

    subgraph AWSAlarms ["Native Resilience"]
        CW["CloudWatch Alarms"]
        DLQ["SQS DLQs"]:::sqs
    end

    subgraph Paging ["Incident Management"]
        PD["PagerDuty"]
        HC["Healthchecks.io"]
        Admin["On-Call Engineer"]
    end

    %% Metrics connections
    TeleInfra & ProcInfra & AlertInfra -- "Scrape Metrics" --> Prometheus
    Prometheus --> Grafana
    Prometheus -- "Trigger Alert" --> Alertmanager
    DLQ -- "Visibility Timeout" --> CW
    Alertmanager & CW --> PD
    PD --> Admin
    Prometheus -. "Dead Man Heartbeat" .-> HC
    HC -- "Missing Heartbeat" --> Admin
