graph TD
    subgraph QueuesLayer ["Asynchronous Queues SQS"]
        AlertQ["Alert Queue"]
        OverrideQ["Override Queue"]
    end

    subgraph ComputeLayer ["Compute Layer ECS Fargate"]
        ProcInfra["Processing Infrastructure"]
        AlertInfra["Alerting Infrastructure Stateless Dispatcher"]
        ProcInfra -- "Validated Crash" --> AlertQ
    end

    subgraph OrchestrationLayer ["AWS Step Functions Alert Orchestration"]
        SFN["State Machine Execution Wait States and SDK Integrations"]
    end

    subgraph StateAndConfigLayer ["Configuration and State Management"]
        SSM["SSM Parameter Store Timers and Thresholds"]
        ExecReg["DynamoDB Execution Registry TTL Managed"]
        ColdDB["DynamoDB Cold Storage Audit and Incident Logs"]
    end

    subgraph IoTLayer ["AWS IoT Core"]
        MQTTStatus["MQTT Topic helmet alert status"]
        MQTTOverride["MQTT Topic helmet alert override"]
    end

    subgraph ThirdPartyLayer ["External Entities"]
        Phone["Smartphone App and HUD"]
        NOK["Next of Kin SMS or Email"]
        EMS["Emergency Services API"]
    end

    AlertQ --> AlertInfra
    AlertInfra -- "Fetch Config" --> SSM
    AlertInfra -- "Write PENDING" --> ExecReg
    AlertInfra -- "StartExecution" --> SFN
    SFN -- "Return ARN" --> AlertInfra
    AlertInfra -- "Update ARN" --> ExecReg

    SFN -- "Publish Countdown or Dismiss" --> MQTTStatus
    MQTTStatus --> Phone

    SFN -- "Timeout or Confirm" --> NOK
    SFN -- "Timeout or Confirm" --> EMS
    SFN -- "Write Audit Log" --> ColdDB

    Phone -- "Cancel or Confirm" --> MQTTOverride
    MQTTOverride -- "IoT Rule" --> OverrideQ
    OverrideQ --> AlertInfra
    AlertInfra -- "Lookup Active ARN" --> ExecReg
    AlertInfra -- "StopExecution" --> SFN
